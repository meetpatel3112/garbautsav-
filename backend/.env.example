# ============================================================
# GarbaUtsav — Environment Variables
# IMPORTANT: Yeh file KABHI bhi GitHub pe upload mat karo!
# ============================================================

# Server
PORT=3000
NODE_ENV=production

# ── RAZORPAY ─────────────────────────────────────────────
# Step 1: razorpay.com pe account banao
# Step 2: Dashboard → Settings → API Keys → Generate Key
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# ── FIREBASE ─────────────────────────────────────────────
# Step 1: console.firebase.google.com → New Project → GarbaUtsav
# Step 2: Project Settings → Service Accounts → Generate New Private Key
# Step 3: JSON file ko backend/ folder mein rakho as firebase-service-account.json
FIREBASE_DATABASE_URL=https://garbautsav-XXXXX-default-rtdb.firebaseio.com

# ── GMAIL (Email Notifications) ──────────────────────────
# Step 1: Gmail → Settings → Security → 2-Step Verification ON
# Step 2: Gmail → Settings → Security → App Passwords → Generate
# Step 3: 16-character password yahan daalo (spaces ke bina)
GMAIL_USER=garbautsav2025@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── WHATSAPP (CallMeBot - Free) ───────────────────────────
# Step 1: wa.me/34644551182 pe message karo: "I allow callmebot to send me messages"
# Step 2: Aapko API key milega
CALLMEBOT_API_KEY=XXXXXXX
ADMIN_WHATSAPP=+919876543210

# ── ADMIN SECRET (Organizer register karne ke liye) ──────
# Koi bhi strong password rakho — sirf aap jaano
ADMIN_SECRET=GarbaUtsav@SuperAdmin#2025

# ── FRONTEND URL (CORS ke liye) ───────────────────────────
FRONTEND_URL=https://garbautsav.netlify.app
